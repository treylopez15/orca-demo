# --- Demo / public deployment ---
# When true, ORCA serves synthetic analytics, blocks Slack/RAG side effects, and the UI shows "Demo Environment".
DEMO_MODE=true

# Uvicorn listen port inside the container or local process.
# Sample docker-compose maps host port 3000 -> container port 8000.
PORT=8000

